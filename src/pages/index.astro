---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServicesCarousel from '../components/ServicesCarousel.astro';
import Portfolio from '../components/Portfolio.astro';
import BrandsMarquee from '../components/BrandsMarquee.astro';
import Testimonials from '../components/Testimonials.astro';
import { whatsappURL } from '../data/site';
---

<BaseLayout>
  <!-- Slider 1: Hero con video -->
  <Hero />

  <!-- Slider 2: Carrusel de servicios (efecto negativo verde) -->
  <ServicesCarousel />

  <!-- Slider 3: Portafolio (link a /proyectos) -->
  <Portfolio />

  <!-- Slider 4: Marquee de marcas en loop -->
  <BrandsMarquee />

  <!-- Slider 5: Testimonios + boton WhatsApp -->
  <Testimonials />

  <!-- CTA final con banner de fondo (vertical en movil, horizontal en PC) -->
  <section id="contact" class="relative py-40 3xl:py-56 px-margin-mobile text-center overflow-hidden">
    <!-- Imagen de fondo responsive: solo descarga la que aplica -->
    <picture class="absolute inset-0 z-0">
      <source media="(max-width: 768px)" srcset="/images/contacto/banner-vertical.png" />
      <img
          src="/images/contacto/banner-horizontal.png"
          alt=""
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
      />
    </picture>

    <!-- Overlay verde de marca + oscurecido para legibilidad.
         Edita los decimales (0.55 / 0.35) para mas o menos intensidad. -->
    <div
        class="absolute inset-0 z-[1]"
        style="background: linear-gradient(to bottom, rgba(11,11,11,0.55), rgba(108,188,136,0.35));"
    ></div>

    <div class="relative z-10 max-w-4xl mx-auto reveal">
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg leading-none">¿Listo para el siguiente nivel?</h2>
      <p class="text-on-surface text-body-lg my-8 max-w-xl mx-auto">
        Tu visión merece un diseño que no solo cumpla expectativas, sino que las defina.
      </p>
      <a
          href={whatsappURL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-primary-container text-on-primary px-12 py-5 rounded-full font-headline-md text-headline-md sea-green-glow hover:scale-105 active:scale-95 transition-all duration-300"
      >
        <svg viewBox="0 0 24 24" class="w-7 h-7" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.999-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Iniciar Proyecto
      </a>
    </div>
  </section>
</BaseLayout>