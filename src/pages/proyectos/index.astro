---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Precalculamos aqui (TypeScript puro) para que el template solo renderice.
// 'ancho': la 1ra campaña, o todas si hay 2 o menos, ocupan el ancho completo
// y se muestran en formato editorial horizontal (imagen + texto al lado).
const marcas = (await getCollection('portafolio'))
    .sort((a, b) => a.data.orden - b.data.orden)
    .map((m) => {
        const total = m.data.campanias.length;
        return {
            slug: m.slug,
            marca: m.data.marca,
            descripcion: m.data.descripcion,
            behance: m.data.behance,
            campanias: m.data.campanias.map((c, j) => ({
                ...c,
                ancho: j === 0 || total <= 2,
                indice: String(j + 1).padStart(2, '0'), // 01, 02, 03 ...
            })),
        };
    });
---

<BaseLayout
        title="Proyectos | ztudio"
        description="Portafolio de campañas y proyectos del estudio ztudio."
>
    <section
            id="portafolio-marcas"
            class="pt-40 3xl:pt-52 pb-32 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto"
    >
        <!-- Encabezado -->
        <div class="mb-14 reveal">
      <span class="text-primary-fixed font-label-sm text-label-sm tracking-[0.2em] uppercase block mb-4">
        Portafolio
      </span>
            <h1 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg leading-none">
                Nuestros Proyectos
            </h1>
            <div class="h-px w-full bg-gradient-to-r from-primary-fixed/60 to-transparent mt-8"></div>
        </div>

        <!-- Layout: sidebar de marcas + panel de campañas -->
        <div class="md:grid md:grid-cols-[minmax(0,260px)_1fr] md:gap-12 lg:gap-16">

            <!-- COLUMNA IZQUIERDA -->
            <div>
                <!-- Selector de marcas (vertical en desktop, chips scrollables en mobile) -->
                <nav
                        class="flex md:flex-col gap-2 overflow-x-auto md:overflow-visible pb-2 md:pb-0
                   [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
                        aria-label="Marcas"
                >
                    {marcas.map((m, i) => (
                            <button
                                    type="button"
                                    data-marca={m.slug}
                                    aria-selected={i === 0 ? 'true' : 'false'}
                                    class="shrink-0 md:w-full text-left whitespace-nowrap px-5 py-3 rounded-lg
                         font-semibold text-base md:text-lg transition-colors
                         bg-surface-container/60 text-on-surface-variant
                         hover:text-on-surface hover:bg-surface-container-high/60
                         aria-selected:bg-surface-container-high aria-selected:text-on-surface aria-selected:font-bold"
                            >
                                {m.marca}
                            </button>
                    ))}
                </nav>

                <!-- Descripción + botón Behance (cambia según la marca activa) -->
                <div class="mt-8 md:mt-12">
                    {marcas.map((m, i) => (
                            <div data-info={m.slug} class:list={[{ hidden: i !== 0 }]}>
                                <p class="font-headline-md text-xl md:text-2xl leading-snug text-primary-fixed mb-6">
                                    {m.descripcion}
                                </p>
                                {m.behance && (
                                        <a
                                                href={m.behance}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="inline-flex items-center gap-2 px-5 py-3 rounded-lg
                               border border-primary-fixed/40 text-primary-fixed font-bold
                               hover:bg-primary-fixed hover:text-on-primary transition-colors"
                                        >
                                            Ver en Behance
                                            <span class="material-symbols-outlined text-xl">arrow_outward</span>
                                        </a>
                                )}
                            </div>
                    ))}
                </div>
            </div>

            <!-- COLUMNA DERECHA: paneles de campañas -->
            <div class="mt-10 md:mt-0">
                {marcas.map((m, i) => (
                        <div data-panel={m.slug} class:list={[{ hidden: i !== 0 }]}>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6 items-start">
                                {m.campanias.map((c) => (
                                        <figure
                                                class:list={[
                                                    "bento-item group relative flex flex-col overflow-hidden rounded-xl",
                                                    "bg-surface-container border border-white/[0.06]",
                                                    "transition-colors duration-500 hover:border-primary-fixed/30",
                                                    // La campaña destacada (ancho) usa layout horizontal en sm+
                                                    c.ancho && "sm:col-span-2 sm:flex-row",
                                                ]}
                                        >
                                            <!-- MARCO DE MEDIA: destacada con proporción fija (object-cover);
                                                 normales a alto natural (object-contain, imagen completa) -->
                                            <div
                                                    class:list={[
                                                        "relative overflow-hidden bg-surface-container-high flex items-center",
                                                        // Card destacada: ocupa ~55% del ancho y alto completo en sm+ (usa object-cover).
                                                        // Card normal: SIN proporción fija -> el alto lo define la imagen a
                                                        // tamaño natural, así se ve completa sin recortar (object-contain).
                                                        c.ancho && "aspect-[4/3] sm:aspect-auto sm:w-[55%] sm:min-h-[300px]",
                                                    ]}
                                            >
                                                {c.tipo === 'video' ? (
                                                        <video
                                                                class:list={[
                                                                    "block w-full transition-transform duration-700 group-hover:scale-[1.03]",
                                                                    c.ancho ? "h-full object-cover" : "h-auto object-contain",
                                                                ]}
                                                                muted loop playsinline preload="none"
                                                        >
                                                            <source src={c.media} type="video/mp4" />
                                                        </video>
                                                ) : (
                                                        <img
                                                                src={c.media}
                                                                alt={`${m.marca} — ${c.titulo}`}
                                                                loading="lazy"
                                                                decoding="async"
                                                                class:list={[
                                                                    "block w-full transition-transform duration-700 group-hover:scale-[1.03]",
                                                                    // Destacada: llena el marco (recorta un poco).
                                                                    // Normal: alto natural, imagen completa SIN recortar.
                                                                    c.ancho ? "h-full object-cover" : "h-auto object-contain",
                                                                ]}
                                                        />
                                                )}

                                                <!-- Índice editorial (01, 02, 03...) -->
                                                <span
                                                        class="absolute top-4 left-4 font-headline-md text-xs font-bold
                                   px-2.5 py-1 rounded-full bg-black/55 backdrop-blur-sm
                                   text-primary-fixed tracking-wider"
                                                >
                                                    {c.indice}
                                                </span>

                                                <!-- Etiqueta 'Destacado' solo en la campaña ancho -->
                                                {c.destacado && (
                                                        <span
                                                                class="absolute top-4 right-4 font-label-sm text-label-sm uppercase
                                     px-3 py-1 rounded-full bg-primary-fixed text-on-primary font-bold"
                                                        >
                                                            Destacado
                                                        </span>
                                                )}
                                            </div>

                                            <!-- TEXTO SIEMPRE VISIBLE -->
                                            <figcaption
                                                    class:list={[
                                                        "relative flex flex-col gap-2 p-6",
                                                        c.ancho && "sm:flex-1 sm:justify-center sm:p-8 sm:gap-3",
                                                    ]}
                                            >
                                                <!-- Número fantasma grande (recurso de marca, Alfa Slab One) -->
                                                {c.ancho && (
                                                        <span
                                                                aria-hidden="true"
                                                                class="pointer-events-none select-none absolute -top-2 right-4
                                     font-display-xl text-6xl md:text-7xl leading-none
                                     text-primary-fixed/10"
                                                        >
                                                            {c.indice}
                                                        </span>
                                                )}

                                                <h3
                                                        class:list={[
                                                            "font-headline-md text-on-surface leading-tight",
                                                            c.ancho ? "text-2xl md:text-3xl" : "text-lg md:text-xl",
                                                        ]}
                                                >
                                                    {c.titulo}
                                                </h3>
                                                <p
                                                        class:list={[
                                                            "font-body-md text-on-surface-variant leading-relaxed",
                                                            c.ancho ? "text-sm md:text-base" : "text-sm",
                                                        ]}
                                                >
                                                    {c.descripcion}
                                                </p>

                                                <!-- Línea de acento que crece en hover -->
                                                <span
                                                        class="mt-1 h-px w-10 bg-primary-fixed/60
                                   transition-all duration-500 group-hover:w-20"
                                                ></span>
                                            </figcaption>
                                        </figure>
                                ))}
                            </div>
                        </div>
                ))}
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* Wipe editorial desde la esquina superior-izquierda.
       CLAVE DE ROBUSTEZ: por defecto las tarjetas están VISIBLES.
       Solo se ocultan (para animar) cuando el JS agrega la clase .wipe-on a la
       sección — cosa que hace únicamente si va a controlar la animación. Así,
       si el JS falla, no corre, o el navegador tiene JS viejo cacheado, las
       tarjetas SIEMPRE se ven (nunca queda el panel en blanco). */
    .bento-item { clip-path: inset(0 0 0 0); }

    :global(#portafolio-marcas.wipe-on) .bento-item {
        transition: clip-path 0.9s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: clip-path;
    }
    :global(#portafolio-marcas.wipe-on) .bento-item:not(.is-in) {
        /* Estado oculto (pre-wipe). Para cambiar la esquina de origen:
           abajo-izquierda -> inset(100% 100% 0 0)
           arriba-derecha  -> inset(0 0 100% 100%) */
        clip-path: inset(0 100% 100% 0);
    }

    /* Accesibilidad / conexiones lentas: sin animación, siempre visibles */
    :global(html.save-data) .bento-item {
        clip-path: none !important;
        transition: none !important;
    }
    @media (prefers-reduced-motion: reduce) {
        .bento-item { clip-path: none !important; transition: none !important; }
    }
</style>

<script>
    const section = document.getElementById('portafolio-marcas');
    if (section) {
        const buttons = Array.from(section.querySelectorAll<HTMLElement>('[data-marca]'));
        const panels = Array.from(section.querySelectorAll<HTMLElement>('[data-panel]'));
        const infos = Array.from(section.querySelectorAll<HTMLElement>('[data-info]'));

        const toggle = (nodes: HTMLElement[], key: string, attr: 'panel' | 'info') =>
            nodes.forEach((n) => n.classList.toggle('hidden', n.dataset[attr] !== key));

        // ¿Animamos? Solo si no hay reduced-motion ni save-data.
        const animate =
            !window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
            !document.documentElement.classList.contains('save-data');

        // Habilita el estado oculto (pre-wipe) SOLO ahora que el JS lo controla.
        // Si el JS no llega aquí, .wipe-on nunca se agrega y las tarjetas se ven.
        if (animate) section.classList.add('wipe-on');

        const reveal = (item: HTMLElement, delay = 0) => {
            item.style.transitionDelay = `${delay}s`;
            item.classList.add('is-in');
        };

        // Observer solo para las tarjetas que quedan DEBAJO del fold: cada una
        // hace su wipe al entrar en viewport.
        const io = new IntersectionObserver(
            (entries) => {
                let d = 0;
                entries.forEach((e) => {
                    if (!e.isIntersecting) return;
                    reveal(e.target as HTMLElement, d);
                    d += 0.08;
                    io.unobserve(e.target);
                });
            },
            { threshold: 0.15 }
        );

        const showPanel = (key: string) => {
            if (!animate) return; // sin animación, las tarjetas ya están visibles

            const panel = panels.find((p) => p.dataset.panel === key);
            if (!panel) return;
            const items = Array.from(panel.querySelectorAll<HTMLElement>('.bento-item'));

            // Reset
            items.forEach((it) => {
                it.classList.remove('is-in');
                it.style.transitionDelay = '';
                io.unobserve(it);
            });

            // Las que YA están en viewport se revelan de inmediato (no dependen
            // del observer). Las de más abajo se observan y animan al bajar.
            let d = 0;
            items.forEach((it) => {
                const r = it.getBoundingClientRect();
                const inView = r.top < window.innerHeight && r.bottom > 0;
                if (inView) {
                    reveal(it, d);
                    d += 0.08;
                } else {
                    io.observe(it);
                }
            });

            // Red de seguridad: si algo quedara oculto (timing raro), se revela.
            window.setTimeout(() => {
                items.forEach((it) => {
                    if (!it.classList.contains('is-in')) reveal(it);
                });
            }, 1200);
        };

        const activate = (key: string) => {
            buttons.forEach((b) => b.setAttribute('aria-selected', String(b.dataset.marca === key)));
            toggle(panels, key, 'panel');
            toggle(infos, key, 'info');
            showPanel(key);
        };

        buttons.forEach((b) =>
            b.addEventListener('click', () => {
                if (b.dataset.marca) activate(b.dataset.marca);
            })
        );

        // Preselección por hash (#pyc, #medik, #tehno) al llegar desde el home
        const fromHash = buttons.find((b) => b.dataset.marca === location.hash.slice(1));
        const initial = fromHash?.dataset.marca ?? buttons[0]?.dataset.marca;
        if (initial) activate(initial);
    }
</script>