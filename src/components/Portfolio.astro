---
import { getCollection } from 'astro:content';

const marcas = await getCollection('portafolio');

// El home muestra SIEMPRE un marco 4:3 uniforme (vitrina).
// Usamos 'mediaHome' (el recorte 4:3 que nos pasaron); si una campaña todavia
// no lo tiene, caemos a 'media' para no romper el render.
const destacados = marcas
    .sort((a, b) => a.data.orden - b.data.orden)
    .flatMap((m) =>
        m.data.campanias
            .filter((c) => c.destacado)
            .map((c) => ({
              ...c,
              src: c.mediaHome ?? c.media,
              marca: m.data.marca,
              slug: m.slug,
            }))
    );
---

<section id="work" class="py-32 bg-surface-container-lowest/50">
  <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="flex justify-between items-center mb-16 reveal">
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg leading-none">Selección Creativa</h2>
      <a
          href="/proyectos"
          class="text-primary-fixed font-bold flex items-center gap-2 hover:translate-x-2 transition-transform"
      >
        Ver todos <span class="material-symbols-outlined">east</span>
      </a>
    </div>

    <div
        class="flex gap-8 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-6
             [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
    >
      {
        destacados.map((c) => (
            <a
                href={`/proyectos#${c.slug}`}
                class="group snap-start shrink-0 w-[85%] md:w-[calc(50%-1rem)] reveal"
            >
              <div class="relative overflow-hidden rounded-xl aspect-[4/3] mb-6 bg-surface-container">
                {c.tipo === 'video' ? (
                    <video
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                        muted
                        loop
                        playsinline
                        preload="metadata"
                    >
                      <source src={c.src} type="video/mp4" />
                    </video>
                ) : (
                    <img
                        src={c.src}
                        alt={`${c.marca} — ${c.titulo}`}
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-8">
                  <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                  <span class="text-primary-fixed font-label-sm text-label-sm uppercase tracking-widest">
                    {c.marca}
                  </span>
                    <h4 class="text-2xl font-bold mt-2">{c.titulo}</h4>
                  </div>
                </div>
              </div>
            </a>
        ))
      }
    </div>
  </div>
</section>
