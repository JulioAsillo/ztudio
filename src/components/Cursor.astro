---
// src/components/Cursor.astro
//
// Cursor personalizado tipo "paper-plane" para ztudio.
// Estrategia de contraste B: relleno verde de marca (#6cbc88) + contorno
// oscuro (#0b0b0b) para que se vea tanto sobre fondos oscuros como sobre
// la seccion blanca (#f6f6f6).
//
// COMO REEMPLAZAR EL SVG POR EL TUYO:
//   - Sustituye el bloque img#cursor-shape por tu propio SVG.
//   - Manten width/height = 28 y viewBox proporcional, o ajusta TIP_X / TIP_Y
//     en el script para que la PUNTA de tu flecha caiga sobre el mouse real.
//
// VALORES AUTO-TESTEABLES (estan al inicio del script):
//   FOLLOW_SPEED   -> suavidad del seguimiento
//                     0.25 = mucho arrastre (lo que causaba el "lag")
//                     0.50 = arrastre casi imperceptible (valor actual)
//                     1.00 = clavado al mouse, CERO lag
//   HOVER_SCALE    -> cuanto crece sobre links/botones
//   TIP_X / TIP_Y  -> offset de la punta dentro del SVG (hotspot)
---

<div id="cursor" aria-hidden="true">
    <img id="cursor-shape" src="/images/cursor.svg" width="28" height="28" alt="" />
</div>

<style>
    #cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 28px;
        height: 28px;
        z-index: 99999;
        pointer-events: none;
        transform-origin: 3px 3px;
        will-change: transform;
        opacity: 0;
        transition: opacity 0.25s ease;
    }

    #cursor.is-ready {
        opacity: 1;
    }

    #cursor-shape {
        display: block;
        /*
         * Se removio filter: drop-shadow() a proposito.
         * Un filtro CSS obliga al navegador a re-pintar el elemento en CADA
         * frame mientras el cursor se mueve -> era una fuente directa de lag.
         * El SVG ya trae un contorno oscuro (#0a0b0b) para contraste, asi que
         * la sombra era redundante. Si quisieras algo de profundidad, hazla
         * DENTRO del propio SVG (un path oscuro desplazado), nunca como filtro
         * CSS sobre un elemento animado.
         */
    }

    @media (hover: hover) and (pointer: fine) {
        :global(html.has-custom-cursor),
        :global(html.has-custom-cursor *) {
            cursor: none !important;
        }
    }
</style>

<script>
    const FOLLOW_SPEED = 0.5;   // sube a 1.0 para eliminar el arrastre por completo
    const HOVER_SCALE = 1.2;
    const TIP_X = 3;
    const TIP_Y = 3;

    const fine = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (fine) {
        document.documentElement.classList.add("has-custom-cursor");

        const cursor = document.getElementById("cursor") as HTMLElement;
        const interactiveSelector =
            'a, button, [role="button"], input, textarea, select, label, summary, .cursor-pointer';

        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        let curX = mouseX;
        let curY = mouseY;

        let targetScale = 1;
        let curScale = 1;

        const followSpeed = reduced ? 1 : FOLLOW_SPEED;
        const scaleSpeed = reduced ? 1 : 0.25;

        // rafId != null significa que el loop esta corriendo.
        // Cuando el cursor alcanza al mouse y no hay movimiento, el loop se
        // detiene (rafId = null) para NO repintar en reposo. Se "despierta"
        // con wake() en cada mousemove / cambio de hover.
        let rafId: number | null = null;

        function wake() {
            if (rafId == null) rafId = requestAnimationFrame(loop);
        }

        window.addEventListener(
            "mousemove",
            (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
                if (!cursor.classList.contains("is-ready")) {
                    cursor.classList.add("is-ready");
                }
                wake();
            },
            { passive: true }
        );

        document.addEventListener("mouseover", (e) => {
            const t = e.target as Element | null;
            if (t && t.closest(interactiveSelector)) {
                targetScale = HOVER_SCALE;
                wake();
            }
        });

        document.addEventListener("mouseout", (e) => {
            const t = e.target as Element | null;
            if (t && t.closest(interactiveSelector)) {
                targetScale = 1;
                wake();
            }
        });

        document.addEventListener("mouseleave", () => {
            cursor.classList.remove("is-ready");
        });

        function loop() {
            const dx = mouseX - curX;
            const dy = mouseY - curY;
            const ds = targetScale - curScale;

            curX += dx * followSpeed;
            curY += dy * followSpeed;
            curScale += ds * scaleSpeed;

            cursor.style.transform =
                "translate3d(" +
                (curX - TIP_X) +
                "px, " +
                (curY - TIP_Y) +
                "px, 0) scale(" +
                curScale +
                ")";

            // ¿ya alcanzo el objetivo? -> dormir el loop (0 repintados en reposo)
            if (Math.abs(dx) < 0.1 && Math.abs(dy) < 0.1 && Math.abs(ds) < 0.001) {
                rafId = null;
                return;
            }
            rafId = requestAnimationFrame(loop);
        }

        wake();
    }
</script>