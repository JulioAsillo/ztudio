---
const socials = ['Instagram', 'LinkedIn', 'Twitter', 'Dribbble'];
const year = new Date().getFullYear();
---

<footer
  class="w-full py-16 bg-surface-container-lowest border-t border-outline-variant/10"
>
  <div
    class="flex flex-col md:flex-row justify-between items-center px-margin-mobile md:px-margin-desktop gap-8 max-w-container-max mx-auto"
  >
    <div class="flex flex-col items-center md:items-start gap-2">
      <span class="font-headline-md text-headline-md text-on-surface tracking-tighter">ztudio</span>
      <p class="font-body-md text-body-md text-on-surface-variant">
        © {year} ztudio. Precision in Design.
      </p>
    </div>
    <div class="flex gap-8">
      {
        socials.map((social) => (
          <a
            href="#"
            class="text-on-surface-variant hover:text-on-surface hover:underline decoration-primary-fixed underline-offset-4 transition-all opacity-80 hover:opacity-100"
          >
            {social}
          </a>
        ))
      }
    </div>
  </div>
</footer>
