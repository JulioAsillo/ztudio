---
import { site } from '../data/site';

const links = [
  { label: 'Servicios', href: '/#services' },
  { label: 'Trabajo', href: '/#work' },
  { label: 'Testimonios', href: '/#testimonios' },
  { label: 'Contacto', href: '/#contact' },
];
---

<nav
  class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-xl border-b border-outline-variant/20"
>
  <div
    class="flex justify-between items-center px-margin-mobile md:px-margin-desktop h-20 max-w-container-max mx-auto"
  >
    <!-- Logo. Archivo en: public/images/logo.svg -->
    <a href="/" class="flex items-center">
      <img src={site.logo} alt="ztudio" class="h-8 w-auto" />
    </a>

    <div class="hidden md:flex gap-10">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-on-surface-variant font-medium hover:text-primary-fixed transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <button
      class="bg-primary-container text-on-primary-container px-6 py-2 rounded-full font-bold transition-transform scale-95 active:scale-90 hover:bg-primary-fixed duration-300"
    >
      Let's Talk
    </button>
  </div>
</nav>
