---
import { testimonios } from '../data/testimonios';
---

<section id="testimonios" class="py-32 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
  <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6 reveal">
    <div>
      <span class="text-primary-fixed font-label-sm text-label-sm tracking-[0.2em] uppercase block mb-4">
        Testimonios
      </span>
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg leading-none">Lo que dicen de nosotros</h2>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {
      testimonios.map((t) => (
        <article class="glass-card p-8 rounded-xl flex flex-col gap-6 reveal">
          <span class="material-symbols-outlined text-primary-fixed text-4xl">format_quote</span>
          <p class="text-on-surface-variant flex-1 leading-relaxed">{t.mensaje}</p>
          <div class="flex items-center gap-4 pt-4 border-t border-outline-variant/20">
            {t.avatar ? (
              <img src={t.avatar} alt={t.nombre} class="w-12 h-12 rounded-full object-cover" />
            ) : (
              <div class="w-12 h-12 rounded-full bg-primary-container text-on-primary flex items-center justify-center font-bold text-lg">
                {t.nombre.charAt(0)}
              </div>
            )}
            <div>
              <p class="font-bold text-on-surface">{t.nombre}</p>
              <p class="text-label-sm text-on-surface-variant">{t.cargo}</p>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
