---
import { site } from '../data/site';
---

<header class="relative min-h-screen flex items-end justify-center overflow-hidden pt-20 pb-24">
  <div class="absolute inset-0 z-0">
    <video
      id="hero-video"
      class="w-full h-full object-cover opacity-0 transition-opacity duration-700"
      muted
      loop
      playsinline
      preload="none"
      poster={site.heroPoster}
      data-desktop={site.heroVideo}
      data-mobile={site.heroVideoMobile}
    >
    </video>
  </div>

  <div class="relative z-10 text-center px-margin-mobile max-w-4xl mx-auto reveal">
    <div class="flex flex-col sm:flex-row gap-6 justify-center">
      <a href="#work" class="bg-primary-container text-on-primary px-8 py-4 rounded-full font-headline-md text-body-md flex items-center justify-center gap-2 sea-green-glow hover:scale-105 transition-transform">
        Explorar Proyectos
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
      <a href="#services" class="border border-outline-variant/40 bg-surface/20 backdrop-blur-md text-primary px-8 py-4 rounded-full font-headline-md text-body-md hover:bg-surface-container-high transition-colors text-center">
        Nuestros Servicios
      </a>
    </div>
  </div>
</header>

<script>
  const v = document.getElementById('hero-video') as HTMLVideoElement | null;

  if (v) {
    // iOS exige muted como PROPIEDAD para permitir autoplay, no basta el atributo
    v.muted = true;

    const DESKTOP = v.dataset.desktop || '';
    const MOBILE = v.dataset.mobile || '';
    const mq = window.matchMedia('(max-width: 768px)');
    let current = '';

    const reveal = function () {
      v.classList.replace('opacity-0', 'opacity-100');
    };
    v.addEventListener('canplay', reveal);

    const pick = function () {
      const wanted = mq.matches ? MOBILE : DESKTOP;
      if (wanted === current || !wanted) return;
      current = wanted;
      v.src = wanted;
      v.load();
      const p = v.play();
      if (p && p.catch) {
        p.catch(reveal);
      }
    };

    const nav = navigator as any;
    const c = nav.connection || nav.mozConnection || nav.webkitConnection;
    const slow = c && (c.saveData || ['slow-2g', '2g', '3g'].indexOf(c.effectiveType) !== -1);

    if (slow) {
      // En conexiones lentas se queda el poster, no se descarga ningun video
      reveal();
    } else {
      v.preload = 'auto';
      pick();
      // Re-evalua al rotar el telefono o cambiar el viewport
      if (mq.addEventListener) {
        mq.addEventListener('change', pick);
      } else {
        mq.addListener(pick);
      }
    }
  }
</script>